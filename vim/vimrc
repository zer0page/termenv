" termenv — core vim configuration
" https://github.com/jacksonc/termenv
" All modular configs live at ~/.vim/termenv/ (symlinked by install.sh)

" Bootstrap vim-plug
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

"==============
" General
set history=10000
filetype plugin indent on
set autoread
set encoding=utf8
set ffs=unix,dos,mac

"==============
" UI
set so=7
set ttimeoutlen=50
set showbreak=↪
set wildmenu
set wildignore=*.o,*~,*.pyc
set ruler
set number
set cmdheight=2
set hidden
set backspace=eol,start,indent
set whichwrap+=<,>,h,l
set ignorecase
set smartcase
set hlsearch
set incsearch
set lazyredraw
set showmatch
set laststatus=2

"==============
" No backup
set nobackup
set nowb
set noswapfile

"==============
" Persistent undo — survives vim restarts
if has('persistent_undo')
  set undodir=~/.vim/undodir
  set undofile
endif

"==============
" Indentation
set expandtab
set smarttab
set shiftwidth=4
set tabstop=4
set ai
set si
set wrap

"==============
" Colors
syntax enable

"==============
" Source modular configs (symlinked under ~/.vim/termenv/)
source ~/.vim/termenv/plugins.vim
source ~/.vim/termenv/keys.vim

" Theme (after plugins loaded)
colo seoul256
hi Normal ctermbg=NONE

" Airline
let g:airline#extensions#tabline#enabled = 1
let g:airline#extensions#tabline#left_sep = ' '
let g:airline#extensions#tabline#left_alt_sep = '|'
let g:airline_theme='bubblegum'
set noshowmode

" ALE (async linting)
let g:ale_sign_error = '✗'
let g:ale_sign_warning = '⚠'
let g:ale_lint_on_text_changed = 'never'
let g:ale_lint_on_enter = 1
let g:ale_lint_on_save = 1

" Tab completion
inoremap <expr><TAB> pumvisible() ? "\<C-n>" : "\<TAB>"
inoremap <silent> <CR> <C-r>=<SID>my_cr_function()<CR>
function! s:my_cr_function()
    return (pumvisible() ? "\<C-y>" : "") . "\<CR>"
endfunction

"==============
" Platform-specific
if $TERMENV_OS == 'mac'
  source ~/.vim/termenv/platform/mac.vim
elseif $TERMENV_OS == 'linux'
  source ~/.vim/termenv/platform/linux.vim
endif

"==============
" Modules (opt-in via ~/.termenv.conf)
if $TERMENV_VIM_GO == '1'
  source ~/.vim/termenv/modules/go.vim
endif

if $TERMENV_VIM_RUST == '1'
  source ~/.vim/termenv/modules/rust.vim
endif

if filereadable(expand('~/.vim/termenv/modules/agent.vim'))
  source ~/.vim/termenv/modules/agent.vim
endif
