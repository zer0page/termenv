# termenv — zsh extensions

source ~/.zsh/termenv/common.sh

# Zsh defaults
setopt CORRECT                # "Did you mean...?" for typos
setopt NO_BEEP                # no terminal bell

# Zsh history options
setopt SHARE_HISTORY          # share across sessions in real time
setopt HIST_IGNORE_ALL_DUPS   # remove older duplicate
setopt HIST_REDUCE_BLANKS     # trim whitespace
setopt INC_APPEND_HISTORY     # write immediately, not on exit

# Git completion — zsh bundles _git natively; compinit activates it
autoload -Uz compinit && compinit -i

# Prompt with git branch — computed in precmd hook so $? is never clobbered
setopt PROMPT_SUBST
__termenv_update_prompt() {
  local _s=$?
  __TERMENV_GIT_BRANCH="$(__git_branch)"
  return $_s
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd __termenv_update_prompt
PROMPT='%n@%m:%~${__TERMENV_GIT_BRANCH}%# '

# fzf keybindings (Ctrl+R history, Ctrl+T files, Alt+C cd)
if command -v fzf &>/dev/null; then
  # fzf 0.48+ ships a built-in init; older versions use shell scripts
  fzf_ver="$(fzf --version 2>/dev/null | awk '{print $1}')"
  IFS=. read -r fzf_major fzf_minor _ <<< "$fzf_ver"
  if (( fzf_major > 0 || (fzf_major == 0 && fzf_minor >= 48) )); then
    source <(fzf --zsh)
  elif [ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ]; then
    source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
  elif [ -f /usr/share/fzf/key-bindings.zsh ]; then
    source /usr/share/fzf/key-bindings.zsh
  fi
  unset fzf_ver fzf_major fzf_minor
fi

# zoxide (autojump replacement, uses 'j' command)
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh --cmd j)"
fi
